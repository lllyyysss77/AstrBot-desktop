# Public announcement service. Set enabled=false for offline/private deployments.
VITE_ASTRBOT_ANNOUNCEMENT_ENABLED=true
VITE_ASTRBOT_ANNOUNCEMENT_URL=https://cloud.astrbot.app/api/v1/announcement
VITE_ASTRBOT_ANNOUNCEMENT_TIMEOUT_MS=3500
VITE_ASTRBOT_ANNOUNCEMENT_RETRIES=1
VITE_ASTRBOT_ANNOUNCEMENT_CACHE_TTL_MS=21600000

# Product documentation and source repository bases.
VITE_ASTRBOT_DOCS_URL=https://docs.astrbot.app
VITE_ASTRBOT_GITHUB_URL=https://github.com/AstrBotDevs/AstrBot
