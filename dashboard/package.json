{
  "name": "astrbot-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "generate:api": "node scripts/generate-openapi.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 95",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{json,ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{json,ts,js}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "quality": "pnpm typecheck && pnpm lint && pnpm lint:styles && pnpm format:check && pnpm test:coverage && pnpm build",
    "preview": "vite preview --port 5051"
  },
  "dependencies": {
    "@hey-api/client-axios": "0.2.12",
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-dialog": "1.1.19",
    "@streamdown/cjk": "1.0.3",
    "@streamdown/code": "1.1.1",
    "@streamdown/math": "1.0.2",
    "@streamdown/mermaid": "1.0.2",
    "axios": "1.13.5",
    "i18next": "26.3.6",
    "katex": "0.16.27",
    "monaco-editor": "0.52.2",
    "pinyin-pro": "3.28.0",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.80.0",
    "react-i18next": "17.0.8",
    "react-router-dom": "7.18.0",
    "streamdown": "2.5.0",
    "yup": "1.7.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.19.9",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "axe-core": "^4.12.1",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.9.5",
    "sass": "1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-scss": "^7.2.0",
    "typescript": "5.1.6",
    "typescript-eslint": "^8.64.0",
    "vite": "6.4.1",
    "vitest": "3.2.4"
  }
}
